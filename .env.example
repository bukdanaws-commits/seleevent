# =============================================================================
#  SELEEVENT — Environment Variables Template
#
#  Three environments available:
#    1. TESTING (local dev)    → .env              — Mock mode, sandbox Midtrans
#    2. STAGING (Cloud Run)    → .env.staging      — Real backend, sandbox Midtrans
#    3. PRODUCTION (Cloud Run) → .env.production   — Real backend, real Midtrans
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  For Cloud Run deployment, use Secret Manager instead of .env:
#    source ~/.seleevent-env
#    ./gcp/deploy-from-cloudshell.sh [staging|production]
#
#  Backend reads: APP_*, DB_*, JWT_*, GOOGLE_*, MIDTRANS_*
#  Frontend reads: NEXT_PUBLIC_*
# =============================================================================

# ── App Configuration ────────────────────────────────────────────────────────
APP_ENV=testing
APP_PORT=8080

# ── Database Configuration (PostgreSQL ONLY) ─────────────────────────────────
# Local dev:
#   DB_HOST=localhost, DB_SSLMODE=disable
# Cloud Run:
#   DB_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME, DB_SSLMODE=disable
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=seleevent
DB_SSLMODE=disable

# ── JWT Configuration ───────────────────────────────────────────────────────
# IMPORTANT: Use strong secrets in staging/production!
# Cloud Run: stored in Secret Manager (auto-generated)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=24h
REFRESH_JWT_EXPIRATION=168h
REFRESH_JWT_SECRET=your-refresh-jwt-secret-change-in-production

# ── Google OAuth (SAMA di semua environment) ────────────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Midtrans Payment Gateway ─────────────────────────────────────────────────
# Get credentials from: https://dashboard.midtrans.com/settings/config_info
#
# SANDBOX keys (untuk testing & staging):
#   MIDTRANS_IS_SANDBOX=true
#   Keys dimulai dengan Mid-server-xxx / Mid-client-xxx (sandbox version)
#
# PRODUCTION keys (untuk production — PEMBAYARAN NYATA!):
#   MIDTRANS_IS_SANDBOX=false
#   Login Midtrans Dashboard → Environment: PRODUCTION → Copy keys
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_CLIENT_KEY=your-client-key
MIDTRANS_IS_SANDBOX=true

# ── Cloud Storage (GCS) ────────────────────────────────────────────────────
# Bucket for QR codes, event images, exports
STORAGE_BUCKET_NAME=eventku_data

# ── Frontend Configuration (Next.js) ────────────────────────────────────────
# LOCAL DEV: Leave API_URL empty, set USE_DIRECT_BACKEND=false, MOCK_MODE=true
# CLOUD RUN: Set API_URL to backend URL, set USE_DIRECT_BACKEND=true, MOCK_MODE=false
NODE_ENV=development
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GO_PORT=8080
NEXT_PUBLIC_USE_DIRECT_BACKEND=false
NEXT_PUBLIC_MOCK_MODE=true
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-client-key
NEXT_PUBLIC_MIDTRANS_IS_SANDBOX=true
