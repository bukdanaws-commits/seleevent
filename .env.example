# =============================================================================
#  SELEEVENT — Environment Variables Template
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  For Cloud Run production, use Secret Manager instead of .env.
#  See: gcp/DEPLOYMENT.md
#
#  Backend reads: APP_*, DB_*, JWT_*, GOOGLE_*, MIDTRANS_*
#  Frontend reads: NEXT_PUBLIC_*
#
#  Two deployment modes:
#    LOCAL DEV:  NEXT_PUBLIC_USE_DIRECT_BACKEND=false (or unset)
#                → FE goes through Caddy gateway via XTransformPort
#    CLOUD RUN:  NEXT_PUBLIC_USE_DIRECT_BACKEND=true
#                NEXT_PUBLIC_API_URL=https://eventku-api-xxxxx.a.run.app
#                → FE calls BE directly (no Caddy proxy)
# =============================================================================

# ── App Configuration (Backend) ──────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080

# ── Database Configuration (PostgreSQL ONLY) ─────────────────────────────────
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=seleevent
DB_SSLMODE=disable

# ── JWT Configuration ────────────────────────────────────────────────────────
# IMPORTANT: Change these in production!
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=24h
REFRESH_JWT_EXPIRATION=168h
REFRESH_JWT_SECRET=your-refresh-jwt-secret-change-in-production

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Midtrans Payment Gateway ─────────────────────────────────────────────────
# Get credentials from: https://dashboard.midtrans.com/settings/config_info
# Use Sandbox credentials for development
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_CLIENT_KEY=your-client-key
MIDTRANS_IS_SANDBOX=true

# ── Cloud Storage (GCS) ──────────────────────────────────────────────────────
# Bucket for QR codes, event images, exports
# Production: eventku_data (asia multi-region)
STORAGE_BUCKET_NAME=eventku_data

# ── Frontend Configuration (Next.js) ────────────────────────────────────────
# LOCAL DEV: Leave API_URL empty, set USE_DIRECT_BACKEND=false
# CLOUD RUN: Set API_URL to backend URL, set USE_DIRECT_BACKEND=true
NODE_ENV=development
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GO_PORT=8080
NEXT_PUBLIC_USE_DIRECT_BACKEND=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-client-key
NEXT_PUBLIC_MIDTRANS_IS_SANDBOX=true
