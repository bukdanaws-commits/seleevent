# ============================================
# SeleEvent - Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values

# ── App ──────────────────────────────────────
APP_ENV=development
APP_PORT=8080
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# ── Database (PostgreSQL) ────────────────────
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=seleevent
DB_SSLMODE=disable

# ── JWT ──────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=24h
REFRESH_JWT_EXPIRATION=168h
REFRESH_JWT_SECRET=your-refresh-jwt-secret-change-in-production

# ── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Midtrans Payment Gateway ─────────────────
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_CLIENT_KEY=your-client-key
MIDTRANS_IS_SANDBOX=true

# ── Encryption ───────────────────────────────
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Next.js Frontend ─────────────────────────
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GO_PORT=8080
NEXT_PUBLIC_USE_DIRECT_BACKEND=true
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-client-key
